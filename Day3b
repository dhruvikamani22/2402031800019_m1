<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Simple CSS Transform Demo</title>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #f0f0f0;
            gap: 20px;
            margin: 0;
        }
        .box {
            width: 100px;
            height: 100px;
            background-color: #3498db;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: sans-serif;
            font-weight: bold;
            border-radius: 8px;
            /* Smooths the transform animation over 0.3 seconds */
            transition: transform 0.3s ease; 
        }
        .move:hover {
            transform: translateY(-20px);
        }
        .spin:hover {
            transform: rotate(45deg);
        }
        .grow:hover {
            transform: scale(1.2);
        }
    </style>
</head>
<body>

    <div class="box move">Move</div>
    <div class="box spin">Spin</div>
    <div class="box grow">Grow</div>

</body>
</html>
