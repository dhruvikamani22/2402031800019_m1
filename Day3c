<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gray layout</title>
    <style>
        *{
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body{
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            font-family: sans-serif;
        }
        .container{
            width: 900px;
            background-color: brown;
            padding: 10px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            text-align: center;
        }
        .header , .footer{
            height: 40px;
            background-color: burlywood;
            width: 100%;
        }
        .main{
            display: flex;
            gap:10px;
            height: 400px;
        }
        .content{
            flex: 2.5;
            background-color: darkgoldenrod;
        }
        .sidebar{
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .sdbox{
            flex:1;
            background-color: blueviolet;
        }
    </style>
        
</head>
<body>
    <div class="container">
        <header class="header">Languages</header>

        <div class="main">
            <main class="content"> list of language</main>

            <aside class="sidebar">
                <div class="sdbox">HTML</div>
                <div class="sdbox">CSS</div>
                <div class="sdbox">Python</div>
            </aside>
        </div>

        <footer class="footer">Thank you</footer>
    </div>
    </body>
</html>
