<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>operators</title>
</head>
<body>
    <h3> Javascript operators</h3>

    <script>
       var x=10;
    //Post/pre increment/decrement
       document.write("x=10")
       document.write("<br> ++x is " + (++x));
       document.write("<br> x++ is  " + (x++));
       document.write("<br> --x is " + (--x));
       document.write("<br> x-- is  " + (x--));

       var y=20;
    // Comparison operators
       document.write("<br> <br> y=20")
       document.write("<br> x==y is "+ (x==y));
       document.write("<br> x!=y is "+ (x!=y));
       document.write("<br> x>=y is "+ (x>=y));
       document.write("<br> x<=y is "+ (x<=y));
       document.write("<br> x>y is "+ (x>y));
       document.write("<br> x&lty is "+ (x<y));

        var a=20;
        var b=10;
        document.write("<br> <br> a=20")
        document.write("<br> b=10")
    // Assignment operators
        document.write("<br> <br> a+=b is "+ (a+=b));
        document.write("<br> a-=b is "+ (a-=b));
        document.write("<br> a*=b is "+ (a*=b));
        document.write("<br> a/=b is "+ (a/=b));
        document.write("<br> a%=b is "+ (a%=b));

    // Logical Operators
        document.write("<br><br> !a is "+ (!a));
        document.write("<br> a&&b is "+ (a&&b));
        document.write("<br> a||b is "+ (a||b));
    </script>
</body>
</html>
